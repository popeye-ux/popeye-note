---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
	const allPosts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	return paginate(allPosts, { pageSize: 9 });
}

const { page } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(date: Date) {
	const y = date.getFullYear();
	const m = String(date.getMonth() + 1).padStart(2, '0');
	const d = String(date.getDate()).padStart(2, '0');
	return `${y}/${m}/${d}`;
}
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead
			title={`Blog${page.currentPage > 1 ? ` - 第 ${page.currentPage} 頁` : ''} | ${SITE_TITLE}`}
			description="所有文章列表"
		/>
	</head>
	<body class="bg-gray-50">
		<Header />
		<main class="max-w-[1140px] mx-auto px-4 py-8 pb-16">

			<!-- Article Grid -->
			<ul class="grid grid-cols-3 gap-6 list-none p-0 m-0 max-[900px]:grid-cols-2 max-[560px]:grid-cols-1">
				{page.data.map((post) => (
					<li>
						<a
							href={`${base}/blog/${post.id}/`}
							class="flex flex-col bg-white border border-gray-200 rounded-xl overflow-hidden h-full no-underline text-inherit hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200"
						>
							<!-- Card Image -->
							<div class="w-full aspect-[4/3] overflow-hidden bg-gray-200 shrink-0">
								{post.data.heroImage ? (
									<Image
										width={400}
										height={300}
										src={post.data.heroImage}
										alt={post.data.title}
										class="w-full h-full object-cover rounded-none"
									/>
								) : (
									<div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300" />
								)}
							</div>

							<!-- Card Body -->
							<div class="p-4 flex flex-col flex-1">
								<!-- Tags -->
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="flex flex-wrap gap-1.5 mb-2.5">
										{post.data.tags.map((tag) => (
											<span class="inline-flex items-center justify-center px-2 py-1 bg-blue-50 rounded text-xs font-bold text-blue-400 whitespace-nowrap">
												{tag}
											</span>
										))}
									</div>
								)}

								<!-- Title -->
								<h2 class="text-base font-bold text-gray-900 m-0 mb-2 leading-snug line-clamp-2">
									{post.data.title}
								</h2>

								<!-- Description -->
								<p class="text-sm text-gray-500 leading-relaxed m-0 pb-3 line-clamp-3 flex-1">
									{post.data.description}
								</p>

								<!-- Date -->
								<time
									class="block text-xs text-gray-400 mt-2.5"
									datetime={post.data.pubDate.toISOString()}
								>
									{formatDate(post.data.pubDate)}
								</time>
							</div>
						</a>
					</li>
				))}
			</ul>

			<!-- Pagination -->
			{page.lastPage > 1 && (
				<div class="mt-12">
					<Pagination
						currentPage={page.currentPage}
						totalPages={page.lastPage}
						baseUrl="/blog"
					/>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
