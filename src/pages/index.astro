---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 9);

function formatDate(date: Date) {
	const y = date.getFullYear();
	const m = String(date.getMonth() + 1).padStart(2, '0');
	const d = String(date.getDate()).padStart(2, '0');
	return `${y}/${m}/${d}`;
}
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-50">
		<Header />
		<main class="max-w-4xl mx-auto px-4 pb-16">

		<!-- Hero Banner -->
		<section class="mt-6 mb-8">
			<img
				src="/hero.png"
				alt="Hero Banner"
				class="w-full h-80 object-cover rounded-xl block border border-gray-300"
			/>
		</section>

			<!-- Article Grid -->
			<ul class="grid grid-cols-3 gap-6 list-none p-0 m-0 max-[900px]:grid-cols-2 max-[560px]:grid-cols-1">
				{posts.map((post) => (
					<li>
						<a
							href={`/blog/${post.id}/`}
							class="flex flex-col bg-white border border-gray-200 rounded-xl overflow-hidden h-full no-underline text-inherit hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200"
						>
							<!-- Card Image -->
							<div class="w-full aspect-[4/3] overflow-hidden bg-gray-200 shrink-0">
								{post.data.heroImage ? (
									<Image
										width={400}
										height={300}
										src={post.data.heroImage}
										alt={post.data.title}
										class="w-full h-full object-cover rounded-none"
									/>
								) : (
									<div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300" />
								)}
							</div>

							<!-- Card Body -->
							<div class="p-4 flex flex-col flex-1">
								<!-- Tags -->
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="flex flex-wrap gap-1.5 mb-2.5">
										{post.data.tags.map((tag) => (
											<span class="inline-block px-2.5 py-0.5 border border-blue-300 rounded-full text-xs text-blue-500 bg-white whitespace-nowrap">
												{tag}
											</span>
										))}
									</div>
								)}

								<!-- Title -->
								<h2 class="text-base font-bold text-gray-900 m-0 mb-2 leading-snug line-clamp-2">
									{post.data.title}
								</h2>

								<!-- Description -->
								<p class="text-sm text-gray-500 leading-relaxed m-0 pb-3 line-clamp-3 flex-1">
									{post.data.description}
								</p>

								<!-- Date -->
								<time
									class="block text-xs text-gray-400 mt-2.5"
									datetime={post.data.pubDate.toISOString()}
								>
									{formatDate(post.data.pubDate)}
								</time>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
