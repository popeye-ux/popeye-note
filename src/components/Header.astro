---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
	<nav class="flex items-center justify-between max-w-[1140px] mx-auto px-4 h-16">
		<a href={`${base}/`} class="text-2xl font-extrabold text-gray-900 uppercase tracking-tight no-underline">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-1">
			<div class="flex items-center">
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/archive">Archive</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			<a
				href={`${base}/search`}
				class="flex items-center justify-center p-2 text-gray-500 rounded-lg hover:text-gray-900 hover:bg-gray-100 transition-colors"
				aria-label="&#x641C;&#x5C0B;"
			>
				<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/>
					<line x1="21" y1="21" x2="16.65" y2="16.65"/>
				</svg>
			</a>
		</div>
	</nav>
</header>